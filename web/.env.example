# Copy to `.env.local` in this folder (Next.js loads it automatically).
# PowerShell: Copy-Item .env.example .env.local
# cmd:         copy .env.example .env.local

# How long Next.js caches the Apify dataset fetch (seconds). Lower = fresher, more API usage.
LIVE_FEED_REVALIDATE_SECONDS=120

# Apify news: reads the last successful run's dataset (actor is scheduled on Apify Console).
APIFY_API_TOKEN=
# Optional override. Default in code: codingfrontend/google-news-scraper
# APIFY_NEWS_ACTOR_ID=
# Max items to display from the Apify dataset (1–25). Default 12.
# APIFY_NEWS_LIMIT=12

# Set to 1 to disable Apify news fetches (curated seed only), e.g. offline demos.
# DISABLE_APIFY_NEWS_FEED=0

# --- Supabase (live event storage) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Vercel Cron secret for /api/cron/ingest-events
# CRON_SECRET=

# Optional: keep ReliefWeb support available for direct testing / fallback utilities.
RELIEFWEB_APPNAME=your-app-or-domain-name
# RELIEFWEB_REPORT_LIMIT=20

# U.S. EIA Open Data — Brent Europe spot snapshot in the feed. Register: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# Set to 1 to skip EIA fetches (ReliefWeb / curated unaffected).
# DISABLE_EIA_FEED=0

# Google Gemini — optional narrative refinement over curated / live-mapped copy.
# Create a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Alternative env name (either works):
# GOOGLE_GENERATIVE_AI_API_KEY=
# Examples: gemini-2.5-flash, gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash

# Feed cards can consume quota quickly. Keep this low; event detail pages still try AI.
# GEMINI_FEED_LIMIT=2

# Optional ingestion-time Gemini refinement. Default 0 keeps cron jobs rule-based only.
# GEMINI_INGEST_LIMIT=0

# Prompt cache in seconds. Applies to successful Gemini responses.
# GEMINI_CACHE_SECONDS=3600

# Set to 0 to disable the local Gemini cache / request dedupe.
# GEMINI_USE_CACHE=1

# Smoke-test the key (from this folder): npm run test:gemini

# Set to 1 to keep baseline copy only (no Gemini calls).
# DISABLE_GEMINI=0
