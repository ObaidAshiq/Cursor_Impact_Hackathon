# Copy to `.env.local` in this folder (Next.js loads it automatically).
# PowerShell: Copy-Item .env.example .env.local
# cmd:         copy .env.example .env.local

# How long Next.js caches the live fetch (seconds). Lower = fresher, more API usage.
LIVE_FEED_REVALIDATE_SECONDS=120

# Apify news actor. The default code path expects a Google News-style actor
# that accepts `query`, `maxItems`, `gl`, `hl`, and `fetchArticleDetails`.
APIFY_API_TOKEN=
# Optional override. Default in code: codingfrontend/google-news-scraper
# APIFY_NEWS_ACTOR_ID=
# APIFY_NEWS_QUERY=India crude oil OR RBI OR wheat export OR inflation
# APIFY_NEWS_LIMIT=12
# APIFY_NEWS_GL=IN
# APIFY_NEWS_HL=en-IN
#
# Advanced: use a different actor input entirely.
# APIFY_NEWS_INPUT_JSON={"query":"India","maxItems":10,"gl":"IN","hl":"en-IN"}

# Set to 1 to disable Apify news fetches (curated seed only), e.g. offline demos.
# DISABLE_APIFY_NEWS_FEED=0

# --- Supabase (recommended): store Apify results; feed reads DB only ---
# Create a project: https://supabase.com/dashboard — run SQL in web/supabase/schema.sql
# Use the service role key only on the server (never NEXT_PUBLIC_*).
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
#
# When these are set, the homepage reads news from `news_articles` instead of calling Apify.
# DISABLE_SUPABASE_NEWS_FEED=0
#
# Daily sync (Apify → Supabase). Protect with a long random secret.
# CRON_SECRET=
# Optional: max items per sync run (1–50). Default 25.
# APIFY_SYNC_MAX_ITEMS=25
# Optional: minimum hours between successful syncs (default 24). Aligns with once-per-day cron.
# APIFY_SYNC_MIN_HOURS_BETWEEN_RUNS=24
#
# Per cron run only: async actor is started once, then we check status every few seconds until
# APIFY_SYNC_RUN_MAX_WAIT_MS elapses (default 90000) or the run finishes. Then we read the dataset
# and upsert whatever rows exist (partial results if the actor is slow or times out).
# APIFY_SYNC_RUN_MAX_WAIT_MS=90000
# APIFY_SYNC_POLL_INTERVAL_MS=2000
#
# Local / manual sync (dev server running):
#   curl -H "Authorization: Bearer YOUR_CRON_SECRET" http://localhost:3000/api/cron/sync-apify-news
# Add ?force=1 to bypass the minimum interval (still requires auth).
#
# Vercel: set CRON_SECRET in Project Env; vercel.json schedules this route once per day (UTC).

# Optional: keep ReliefWeb support available for direct testing / fallback utilities.
RELIEFWEB_APPNAME=your-app-or-domain-name
# RELIEFWEB_REPORT_LIMIT=20

# U.S. EIA Open Data — Brent Europe spot snapshot in the feed. Register: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# Set to 1 to skip EIA fetches (ReliefWeb / curated unaffected).
# DISABLE_EIA_FEED=0

# Google Gemini — optional narrative refinement over curated / live-mapped copy.
# Create a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Alternative env name (either works):
# GOOGLE_GENERATIVE_AI_API_KEY=
# Examples: gemini-2.5-flash, gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash

# Feed cards can consume quota quickly. Keep this low; event detail pages still try AI.
# GEMINI_FEED_LIMIT=2

# Prompt cache in seconds. Applies to successful Gemini responses.
# GEMINI_CACHE_SECONDS=3600

# Set to 0 to disable the local Gemini cache / request dedupe.
# GEMINI_USE_CACHE=1

# Smoke-test the key (from this folder): npm run test:gemini

# Set to 1 to keep baseline copy only (no Gemini calls).
# DISABLE_GEMINI=0
